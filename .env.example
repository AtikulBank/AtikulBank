# cTrader FIX Connection Settings
# Copy this file to .env and fill in your credentials
#
# IMPORTANT: FIX API Password Setup
# -----------------------------------
# Your cTrader account uses Google OAuth login, so there is NO traditional password.
# The FIX API requires a SEPARATE dedicated password set via:
#   cTrader → Settings → FIX API → Change Password
#
# Set that password here. If it contains special characters like #, wrap in quotes.
# Example: FIX_PASSWORD="MyP@ssw0rd#123"

FIX_HOST=demo-uk-eqx-01.p.c-trader.com
SENDER_COMP_ID=demo.ctrader.5832984
TARGET_COMP_ID=cServer
FIX_PASSWORD="your_fix_api_password_here"